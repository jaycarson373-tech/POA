# Paste into Railway → poa-workers → Variables → Raw Editor.
# Do not set PORT; Railway supplies it automatically.

NODE_ENV=production
WEB_APP_URL=https://YOUR-POA-DOMAIN.com

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVER_ONLY_SERVICE_ROLE_KEY
# Use the Supabase Session Pooler connection string on port 5432 for a persistent Railway worker.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT-REF:YOUR-PASSWORD@aws-YOUR-REGION.pooler.supabase.com:5432/postgres?sslmode=require

X_CLIENT_ID=REPLACE_WITH_X_OAUTH2_CLIENT_ID
X_CLIENT_SECRET=REPLACE_WITH_X_OAUTH2_CLIENT_SECRET
X_BEARER_TOKEN=REPLACE_WITH_X_APP_BEARER_TOKEN
X_OAUTH_SCOPES=tweet.read users.read offline.access

TOKEN_ENCRYPTION_KEY=REPLACE_WITH_SAME_VALUE_AS_VERCEL
INTERNAL_API_SECRET=REPLACE_WITH_SAME_VALUE_AS_VERCEL
CRON_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32

SOLANA_NETWORK=mainnet-beta
SOLANA_RPC_URL=https://REPLACE_WITH_PRIVATE_RPC_URL
TREASURY_PUBLIC_KEY=REPLACE_WITH_PUBLIC_SOLANA_ADDRESS
ADMIN_WALLET_ADDRESSES=ADDRESS_ONE,ADDRESS_TWO

# Keep payouts manual for launch. Never paste a treasury private key here.
PAYOUT_MODE=manual
PAYOUT_SIGNER_PROVIDER=manual
PAYOUT_SIGNER_KEY_ID=

# Reserved for the buyback worker. Leave disabled until the signed transaction
# path has passed mainnet security review and a minimum operating reserve is set.
BUYBACK_MODE=disabled
BUYBACK_INTERVAL_SECONDS=300
BUYBACK_ALLOCATION_BPS=5000
BUYBACK_MIN_RESERVE_LAMPORTS=REPLACE_WITH_NONZERO_RESERVE
BUYBACK_OUTPUT_MINT=8MWh6MXsd64vgxrtjN2HygwJLR8g6fTGPTGJUXVBpump
BUYBACK_SIGNER_PROVIDER=manual
BUYBACK_SIGNER_KEY_ID=

X_POLL_INTERVAL_SECONDS=900
X_FINAL_POLL_INTERVAL_SECONDS=60
SCORE_FORMULA_VERSION=v1
LOG_LEVEL=info
