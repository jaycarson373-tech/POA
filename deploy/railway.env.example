# Railway → Variables → Raw Editor. Never commit real secret values.
# Railway supplies PORT automatically.
NODE_ENV=production
WEB_APP_URL=https://www.proofofattention.fun
CORS_ALLOWED_ORIGINS=https://www.proofofattention.fun,https://proofofattention.fun

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=REPLACE_AND_SEAL

SOLANA_RPC_URL=https://REPLACE_WITH_PRIVATE_MAINNET_RPC
POA_TOKEN_MINT=8MWh6MXsd64vgxrtjN2HygwJLR8g6fTGPTGJUXVBpump
POA_TOKEN_DECIMALS=6
POA_MINIMUM_HOLDER_TOKENS=500000
WALLET_MINIMUM_AGE_DAYS=7
X_MINIMUM_AGE_DAYS=90
X_MINIMUM_FOLLOWERS=25
POA_SELL_PENALTY_BPS=5000

X_BEARER_TOKEN=REPLACE_AND_SEAL
X_OAUTH_SCOPES=tweet.read users.read follows.read offline.access
X_POLL_INTERVAL_SECONDS=300
X_FOLLOWER_QUALITY_INTERVAL_SECONDS=86400

TOKEN_ENCRYPTION_KEY=REPLACE_WITH_A_NEW_32_BYTE_RANDOM_SECRET
INTERNAL_API_SECRET=REPLACE_WITH_A_DIFFERENT_RANDOM_SECRET

# Five-minute POA leaderboard airdrops. The amount is in mint base units.
# For a 6-decimal mint, 1 POA = 1000000 base units.
AUTO_REWARDS_MODE=live
AUTO_REWARD_INTERVAL_SECONDS=300
POA_REWARD_EPOCH_AMOUNT_RAW=REPLACE_WITH_EXPLICIT_PER_EPOCH_BUDGET
AUTO_REWARD_MAX_RECIPIENTS=25
AUTO_REWARD_MINIMUM_PAYOUT_RAW=1
POA_REWARD_WALLET_PUBLIC_KEY=REPLACE_WITH_LIMITED_HOT_WALLET_PUBLIC_KEY
POA_REWARD_WALLET_PRIVATE_KEY=REPLACE_AND_SEAL_WITH_BASE58_OR_JSON_64_BYTE_SECRET
POA_REWARD_WALLET_MIN_RESERVE_RAW=REPLACE_WITH_NONZERO_TOKEN_RESERVE

# Sponsor campaign funding, refunds, and final SOL/SPL winner payouts.
CAMPAIGN_COLLECTION_WALLET=REPLACE_WITH_SEPARATE_COLLECTION_WALLET_PUBLIC_KEY
CAMPAIGN_COLLECTION_WALLET_PRIVATE_KEY=REPLACE_AND_SEAL_WITH_BASE58_OR_JSON_64_BYTE_SECRET

# Five-minute SOL → POA buybacks using 50% of the balance above the reserve.
BUYBACK_MODE=live
BUYBACK_INTERVAL_SECONDS=300
BUYBACK_ALLOCATION_BPS=5000
BUYBACK_MIN_RESERVE_LAMPORTS=REPLACE_WITH_NONZERO_SOL_RESERVE
BUYBACK_OUTPUT_MINT=8MWh6MXsd64vgxrtjN2HygwJLR8g6fTGPTGJUXVBpump
BUYBACK_WALLET_PUBLIC_KEY=REPLACE_WITH_FEE_WALLET_PUBLIC_KEY
BUYBACK_WALLET_PRIVATE_KEY=REPLACE_AND_SEAL_WITH_BASE58_OR_JSON_64_BYTE_SECRET
JUPITER_API_KEY=REPLACE_AND_SEAL
