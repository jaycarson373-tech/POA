# Paste into Vercel → Project → Settings → Environment Variables.
# Apply to Production, Preview, and Development unless noted otherwise.

NEXT_PUBLIC_APP_URL=https://YOUR-POA-DOMAIN.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVER_ONLY_SERVICE_ROLE_KEY

# Use the same values in Vercel and Railway.
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_OPENSSL_RAND_BASE64_32
INTERNAL_API_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_32

NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
SOLANA_RPC_URL=https://REPLACE_WITH_PRIVATE_RPC_URL
TREASURY_PUBLIC_KEY=REPLACE_WITH_PUBLIC_SOLANA_ADDRESS

# Add after Railway gives the worker/API service a public domain.
RAILWAY_API_URL=https://YOUR-POA-API.up.railway.app
