# Browser-safe Supabase and app values
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_CONTRACT_ADDRESS=8MWh6MXsd64vgxrtjN2HygwJLR8g6fTGPTGJUXVBpump
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta

# Server-only Supabase values
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# X OAuth and API (worker/server only)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_BEARER_TOKEN=
X_OAUTH_SCOPES=tweet.read users.read offline.access

# Solana data (never expose a paid RPC key with NEXT_PUBLIC_)
SOLANA_RPC_URL=
TREASURY_PUBLIC_KEY=

# Service security and administration
TOKEN_ENCRYPTION_KEY=
INTERNAL_API_SECRET=
CRON_SECRET=
ADMIN_WALLET_ADDRESSES=
RAILWAY_API_URL=

# Payouts start in manual mode
PAYOUT_MODE=manual
PAYOUT_SIGNER_PROVIDER=manual
PAYOUT_SIGNER_KEY_ID=

# Buyback execution remains disabled until the Railway worker and managed signer
# are deployed. Never paste a raw Solana private key into this file.
BUYBACK_MODE=disabled
BUYBACK_INTERVAL_SECONDS=300
BUYBACK_ALLOCATION_BPS=5000
BUYBACK_MIN_RESERVE_LAMPORTS=
BUYBACK_OUTPUT_MINT=8MWh6MXsd64vgxrtjN2HygwJLR8g6fTGPTGJUXVBpump
BUYBACK_SIGNER_PROVIDER=manual
BUYBACK_SIGNER_KEY_ID=
