{
  "name": "poa-proof-of-attention",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "dev:vercel": "next dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "build:vercel": "next build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "typecheck": "tsc --noEmit -p tsconfig.vercel.json",
    "typecheck:railway": "tsc --noEmit -p railway/tsconfig.json",
    "start:railway": "tsx railway/server.ts",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@solana-program/system": "^0.12.1",
    "@solana-program/token": "^0.13.0",
    "@solana/kit": "^6.5.0",
    "@solana/wallet-standard-features": "^1.4.0",
    "@supabase/supabase-js": "^2.110.7",
    "@wallet-standard/app": "^1.1.1",
    "@wallet-standard/base": "^1.1.1",
    "@wallet-standard/features": "^1.1.1",
    "bs58": "^6.0.0",
    "drizzle-orm": "0.45.2",
    "framer-motion": "^12.42.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tsx": "^4.23.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
